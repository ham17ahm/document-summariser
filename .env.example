# Copy this file to .env and fill in real values.
# Never commit .env.

# Google Cloud Vision OCR
# Option A: path to a Google service-account JSON credentials file.
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/google-service-account.json
GOOGLE_CLOUD_PROJECT=your-google-cloud-project-id

# Gemini / Google AI correction and summarisation
# Use the key required by the Gemini SDK/adapter selected in config.
GEMINI_API_KEY=replace-me
GOOGLE_API_KEY=replace-me

# Anthropic Claude
ANTHROPIC_API_KEY=replace-me

# OpenAI GPT
OPENAI_API_KEY=replace-me

# DeepSeek
DEEPSEEK_API_KEY=replace-me

# Optional runtime defaults
DOCUMENT_SUMMARISER_CONFIG=config/config.yaml
DOCUMENT_SUMMARISER_OUTPUT_DIR=./runs/
